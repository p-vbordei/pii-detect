{
  "name": "pii-detect",
  "version": "0.1.0",
  "description": "Detect personally identifiable information (emails, phones, SSNs, credit cards with Luhn, IBANs with checksum, IPs, Bitcoin addresses). Zero dependencies.",
  "keywords": ["pii", "privacy", "redact", "luhn", "credit-card", "ssn", "iban"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=20" },
  "author": { "name": "Vlad Bordei", "email": "bordeivlad@gmail.com", "url": "https://github.com/p-vbordei" },
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/p-vbordei/pii-detect.git" },
  "bugs": { "url": "https://github.com/p-vbordei/pii-detect/issues" },
  "homepage": "https://github.com/p-vbordei/pii-detect#readme",
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.0.0" }
}
